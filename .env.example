# ===========================================
# STRIPE CONFIGURATION
# ===========================================
# Get these keys from your Stripe Dashboard:
# https://dashboard.stripe.com/apikeys

# Stripe Secret Key (starts with sk_test_ or sk_live_)
# Used for server-side Stripe operations
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
# Used for client-side Stripe Elements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# ===========================================
# OPTIONAL: STRIPE WEBHOOK (for production)
# ===========================================
# Webhook secret for verifying Stripe webhook events
# Get this from: https://dashboard.stripe.com/webhooks
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# NOTES
# ===========================================
# - For development, use test keys (sk_test_*, pk_test_*)
# - For production, use live keys (sk_live_*, pk_live_*)
# - Never commit real keys to version control
# - Copy this file to .env.local and fill in your actual keys
